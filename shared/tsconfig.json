{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "types/**/*.ts",
    "contracts/**/*.ts",
    "constants/**/*.ts",
    "schemas/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
